{
  "name": "mucyan-corporate-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit",
    "build": "pnpm typecheck && vite build && node scripts/prepare-sites-build.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "pnpm build && node --test tests/site.test.mjs"
  },
  "dependencies": {
    "vue": "3.5.26"
  },
  "devDependencies": {
    "@esbuild/darwin-x64": "0.27.2",
    "@rollup/rollup-darwin-x64": "4.54.0",
    "@types/node": "24.10.4",
    "@vitejs/plugin-vue": "6.0.3",
    "typescript": "5.9.3",
    "vite": "7.3.0",
    "vue-tsc": "3.2.1"
  }
}
